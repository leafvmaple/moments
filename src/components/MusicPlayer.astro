---
import Icon from './Icon.astro';
import playlist from '../data/playlist.json';

interface Track {
  title: string;
  artist?: string;
  src: string;
  cover?: string;
}

const tracks = playlist as Track[];
const playlistJson = JSON.stringify(tracks);
---

<div class="player" data-music-player>
  <img class="player-cover" alt="" data-cover />
  <div class="player-meta">
    <span class="player-title" data-title>—</span>
    <span class="player-artist" data-artist></span>
  </div>
  <div class="player-controls">
    <button type="button" class="ctrl-btn" data-prev aria-label="上一首">
      <Icon name="skipBack" size={13} />
    </button>
    <button type="button" class="ctrl-btn play" data-play aria-label="播放">
      <span class="icon-play"><Icon name="play" size={13} /></span>
      <span class="icon-pause" hidden><Icon name="pause" size={13} /></span>
    </button>
    <button type="button" class="ctrl-btn" data-next aria-label="下一首">
      <Icon name="skipForward" size={13} />
    </button>
  </div>
  <audio data-audio preload="none"></audio>
</div>

<script is:inline define:vars={{ playlistJson }}>
  (() => {
    const root = document.querySelector('[data-music-player]');
    if (!root) return;
    const tracks = JSON.parse(playlistJson);
    if (!tracks.length) return;

    const audio = root.querySelector('[data-audio]');
    const cover = root.querySelector('[data-cover]');
    const titleEl = root.querySelector('[data-title]');
    const artistEl = root.querySelector('[data-artist]');
    const playBtn = root.querySelector('[data-play]');
    const iconPlay = root.querySelector('.icon-play');
    const iconPause = root.querySelector('.icon-pause');
    const STORAGE = 'moments:player';

    let state = { idx: 0, t: 0, playing: false };
    try {
      const raw = localStorage.getItem(STORAGE);
      if (raw) state = { ...state, ...JSON.parse(raw) };
    } catch {}
    if (state.idx >= tracks.length) state.idx = 0;

    function persist() {
      try {
        localStorage.setItem(
          STORAGE,
          JSON.stringify({ idx: state.idx, t: audio.currentTime || 0, playing: !audio.paused })
        );
      } catch {}
    }
    function load(idx, autoplay) {
      state.idx = idx;
      const tr = tracks[idx];
      audio.src = tr.src;
      titleEl.textContent = tr.title;
      artistEl.textContent = tr.artist || '';
      if (tr.cover) {
        cover.src = tr.cover;
        cover.hidden = false;
      } else {
        cover.hidden = true;
      }
      audio.currentTime = state.t || 0;
      if (autoplay) audio.play().catch(() => {});
      persist();
    }
    function updateIcons() {
      iconPlay.hidden = !audio.paused;
      iconPause.hidden = audio.paused;
    }
    playBtn.addEventListener('click', () => {
      if (audio.paused) audio.play().catch(() => {});
      else audio.pause();
    });
    root.querySelector('[data-prev]').addEventListener('click', () => {
      state.t = 0;
      load((state.idx - 1 + tracks.length) % tracks.length, true);
    });
    root.querySelector('[data-next]').addEventListener('click', () => {
      state.t = 0;
      load((state.idx + 1) % tracks.length, true);
    });
    audio.addEventListener('play', updateIcons);
    audio.addEventListener('pause', () => {
      updateIcons();
      persist();
    });
    audio.addEventListener('ended', () => {
      state.t = 0;
      load((state.idx + 1) % tracks.length, true);
    });
    audio.addEventListener('timeupdate', () => {
      if ((audio.currentTime | 0) !== (state.t | 0)) {
        state.t = audio.currentTime;
        if (((audio.currentTime * 10) | 0) % 30 === 0) persist();
      }
    });
    window.addEventListener('beforeunload', persist);

    load(state.idx, state.playing);
    updateIcons();
  })();
</script>

<style>
  .player {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 4px 10px 4px 4px;
    max-width: 280px;
  }

  .player-cover {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .player-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
    max-width: 110px;
  }

  .player-title {
    font-size: 12px;
    color: var(--color-heading);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .player-artist {
    font-size: 10px;
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .player-controls {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .ctrl-btn {
    background: transparent;
    border: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .ctrl-btn:hover {
    background: var(--color-bg-card);
    color: var(--color-primary);
  }

  .ctrl-btn.play {
    background: var(--color-primary);
    color: #fff;
    width: 24px;
    height: 24px;
  }

  .ctrl-btn.play:hover {
    background: var(--color-primary-hover);
    color: #fff;
  }

  @media (max-width: 900px) {
    .player {
      display: none;
    }
  }
</style>
