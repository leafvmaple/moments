---
import Icon from './Icon.astro';

const links = [
  { href: '/', label: '首页', icon: 'home' },
  { href: '/album', label: '相册', icon: 'image' },
  { href: 'https://leafvmaple.com', label: '技术博客', icon: 'link', external: true },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<aside class="app-aside">
  <a href="/" class="brand">
    <span class="brand-mark">M</span>
    <span class="brand-text">moments</span>
  </a>

  <div class="profile">
    <div class="avatar">
      <span>叶</span>
    </div>
    <div class="profile-name">
      leafvmaple <Icon name="chevronDown" size={12} />
    </div>
    <div class="profile-bio">在代码缝隙里记录生活</div>
  </div>

  <nav class="nav">
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-item', pathname === l.href && 'active']}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener noreferrer' : undefined}
        >
          <Icon name={l.icon} size={16} />
          <span>{l.label}</span>
          <Icon name="chevronRight" size={12} class="nav-chevron" />
        </a>
      ))
    }
  </nav>

  <div class="aside-footer">
    <a href="https://github.com/leafvmaple/moments" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <Icon name="github" size={14} />
    </a>
    <a href="/rss.xml" aria-label="RSS">
      <Icon name="rss" size={14} />
    </a>
    <a href="https://leafvmaple.com" target="_blank" rel="noopener noreferrer" aria-label="技术博客">
      <Icon name="link" size={14} />
    </a>
  </div>
</aside>

<style>
  .app-aside {
    padding: var(--space-md) 0 var(--space-sm);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0 var(--space-lg) var(--space-md);
    color: var(--color-heading);
    font-size: 16px;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--color-primary);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
  }

  .brand-text {
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .profile {
    text-align: center;
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent-green));
    margin: 0 auto var(--space-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 32px;
    font-weight: 300;
  }

  .profile-name {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-heading);
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .profile-bio {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .nav {
    display: flex;
    flex-direction: column;
    padding: var(--space-sm) 0;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 10px var(--space-lg);
    color: var(--color-text);
    font-size: 13px;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .nav-item:hover {
    background: var(--color-bg-subtle);
    color: var(--color-heading);
  }

  .nav-item.active {
    background: var(--color-bg-card);
    color: var(--color-heading);
    border-left: 2px solid var(--color-primary);
    padding-left: calc(var(--space-lg) - 2px);
  }

  .nav-item span {
    flex: 1;
  }

  .nav-chevron {
    opacity: 0.35;
  }

  .aside-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .aside-footer a {
    color: inherit;
    transition: color 0.15s ease;
  }

  .aside-footer a:hover {
    color: var(--color-primary);
  }
</style>
