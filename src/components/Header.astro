---
const links = [
  { href: '/', label: '首页' },
  { href: '/album', label: '相册' },
  { href: 'https://leafvmaple.com', label: '技术博客', external: true },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-mark">M</span>
      <span class="brand-text">moments</span>
    </a>
    <nav class="site-nav">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={pathname === l.href ? 'active' : ''}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener noreferrer' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <button class="theme-toggle" type="button" aria-label="切换主题">
        <span class="theme-icon-light">☀</span>
        <span class="theme-icon-dark">☾</span>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector('.theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  }
</script>

<style>
  .site-header {
    background: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-h);
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(180%) blur(8px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 18px;
    color: var(--color-heading);
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--color-primary);
    color: #fff;
    font-weight: 600;
    font-size: 15px;
  }

  .brand-text {
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .site-nav a {
    color: var(--color-text);
    font-size: 14px;
    position: relative;
    padding: 4px 0;
  }

  .site-nav a.active {
    color: var(--color-primary);
  }

  .site-nav a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    width: 32px;
    height: 32px;
    cursor: pointer;
    color: var(--color-text);
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .theme-icon-light {
    display: none;
  }
  .theme-icon-dark {
    display: inline;
  }

  :global(html[data-theme='dark']) .theme-icon-light {
    display: inline;
  }
  :global(html[data-theme='dark']) .theme-icon-dark {
    display: none;
  }

  @media (max-width: 600px) {
    .site-nav {
      gap: var(--space-md);
    }
    .brand-text {
      display: none;
    }
  }
</style>
