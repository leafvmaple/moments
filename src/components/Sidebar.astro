---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  excludeSlug?: string;
}

const { excludeSlug } = Astro.props;

const allPosts = await getCollection('posts');
const visible = excludeSlug ? allPosts.filter((p) => p.id !== excludeSlug) : allPosts;
const sorted = [...visible].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postCount = allPosts.length;
const commentCount = 0;

const blogStart = new Date('2026-05-27');
const today = new Date();
const days = Math.max(1, Math.floor((today.getTime() - blogStart.getTime()) / 86400000) + 1);
const years = Math.floor(days / 365);
const remainingDays = days % 365;
const runningStr = years > 0 ? `${years}年${remainingDays}天` : `${days}天`;

const lastDate = sorted[0]?.data.date ?? blogStart;
const minutesSince = Math.max(1, Math.floor((today.getTime() - lastDate.getTime()) / 60000));
const lastActivityStr =
  minutesSince < 60
    ? `${minutesSince}分钟前`
    : minutesSince < 1440
      ? `${Math.floor(minutesSince / 60)}小时前`
      : `${Math.floor(minutesSince / 1440)}天前`;

const tagCounts = new Map<string, number>();
for (const p of allPosts) for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const tags = Array.from(tagCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

const recentPosts = sorted.slice(0, 3);
const featured = [...visible]
  .sort((a, b) => b.data.tags.length - a.data.tags.length || b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const randomPool = visible.map((p) => ({
  slug: p.id,
  title: p.data.title,
  cover: p.data.cover,
}));
const randomPoolJson = JSON.stringify(randomPool);

const renderList = (
  posts: typeof recentPosts,
  variant: 'recent' | 'featured'
) => posts.map((p) => ({
  href: `/posts/${p.id}`,
  title: p.data.title,
  cover: p.data.cover,
  meta:
    variant === 'featured'
      ? `${p.data.tags.length} 个标签`
      : '0',
  variant,
}));

const recentItems = renderList(recentPosts, 'recent');
const featuredItems = renderList(featured, 'featured');
---

<aside class="content-sidebar">
  <section class="panel quick-panel">
    <div class="quick-tabs" role="tablist">
      <button class="quick-tab" type="button" data-tab="featured" role="tab" aria-label="推荐">
        <Icon name="heart" size={16} />
      </button>
      <button class="quick-tab active" type="button" data-tab="recent" role="tab" aria-label="最近">
        <Icon name="messageCircle" size={16} />
      </button>
      <button class="quick-tab" type="button" data-tab="random" role="tab" aria-label="随机">
        <Icon name="gift" size={16} />
      </button>
    </div>

    <div class="quick-panes">
      <div class="quick-pane" data-pane="featured" hidden>
        {
          featuredItems.length === 0 ? (
            <div class="quick-empty">暂无内容</div>
          ) : (
            featuredItems.map((it) => (
              <a class="recent-row" href={it.href}>
                {it.cover ? (
                  <img class="recent-thumb" src={it.cover} alt={it.title} loading="lazy" />
                ) : (
                  <div class="recent-thumb recent-thumb-placeholder">
                    <Icon name="fileText" size={16} />
                  </div>
                )}
                <div class="recent-text">
                  <span class="recent-title">{it.title}</span>
                  <span class="recent-meta">
                    <Icon name="heart" size={11} />
                    <span>{it.meta}</span>
                  </span>
                </div>
              </a>
            ))
          )
        }
      </div>

      <div class="quick-pane" data-pane="recent">
        {
          recentItems.length === 0 ? (
            <div class="quick-empty">还没有文章</div>
          ) : (
            recentItems.map((it) => (
              <a class="recent-row" href={it.href}>
                {it.cover ? (
                  <img class="recent-thumb" src={it.cover} alt={it.title} loading="lazy" />
                ) : (
                  <div class="recent-thumb recent-thumb-placeholder">
                    <Icon name="fileText" size={16} />
                  </div>
                )}
                <div class="recent-text">
                  <span class="recent-title">{it.title}</span>
                  <span class="recent-meta">
                    <Icon name="messageCircle" size={11} />
                    <span>{it.meta}</span>
                  </span>
                </div>
              </a>
            ))
          )
        }
      </div>

      <div class="quick-pane" data-pane="random" hidden>
        <div class="quick-empty random-empty">加载中…</div>
      </div>
    </div>
  </section>

  <section class="panel">
    <h4 class="panel-title">博客信息</h4>
    <div class="stat-rows">
      <div class="stat-row">
        <Icon name="fileText" size={13} />
        <span class="stat-label">文章数目</span>
        <span class="badge">{postCount}</span>
      </div>
      <div class="stat-row">
        <Icon name="messageCircle" size={13} />
        <span class="stat-label">评论数目</span>
        <span class="badge">{commentCount}</span>
      </div>
      <div class="stat-row">
        <Icon name="calendar" size={13} />
        <span class="stat-label">运行天数</span>
        <span class="badge">{runningStr}</span>
      </div>
      <div class="stat-row">
        <Icon name="activity" size={13} />
        <span class="stat-label">最后活动</span>
        <span class="badge">{lastActivityStr}</span>
      </div>
    </div>
  </section>

  {
    tags.length > 0 && (
      <section class="panel">
        <h4 class="panel-title">标签云</h4>
        <div class="tag-cloud">
          {tags.map((t) => (
            <a class="badge tag-link" href={`/tags/${t.name}`}>
              {t.name} <em>{t.count}</em>
            </a>
          ))}
        </div>
      </section>
    )
  }
</aside>

<script is:inline define:vars={{ randomPoolJson }}>
  (() => {
    const tabs = document.querySelectorAll('.quick-tab');
    const panes = document.querySelectorAll('.quick-pane');
    if (!tabs.length) return;
    tabs.forEach((t) => {
      t.addEventListener('click', () => {
        const key = t.dataset.tab;
        tabs.forEach((x) => x.classList.toggle('active', x === t));
        panes.forEach((p) => {
          p.hidden = p.dataset.pane !== key;
        });
        if (key === 'random') renderRandom();
      });
    });

    function escape(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[c]));
    }
    function renderRandom() {
      const pane = document.querySelector('[data-pane="random"]');
      if (!pane) return;
      const pool = JSON.parse(randomPoolJson);
      if (!pool.length) {
        pane.innerHTML = '<div class="quick-empty">暂无文章</div>';
        return;
      }
      const shuffled = pool.slice().sort(() => Math.random() - 0.5).slice(0, 3);
      pane.innerHTML = shuffled
        .map((p) => `
        <a class="recent-row" href="/posts/${p.slug}">
          ${p.cover
            ? `<img class="recent-thumb" src="${escape(p.cover)}" alt="${escape(p.title)}" loading="lazy" />`
            : '<div class="recent-thumb recent-thumb-placeholder"></div>'}
          <div class="recent-text">
            <span class="recent-title">${escape(p.title)}</span>
            <span class="recent-meta">来一篇看看 →</span>
          </div>
        </a>`)
        .join('');
    }
  })();
</script>

<style>
  .quick-panel {
    padding: 0;
    overflow: hidden;
  }

  .quick-tabs {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .quick-tab {
    background: transparent;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .quick-tab:hover {
    background: var(--color-bg-subtle);
    color: var(--color-primary);
  }

  .quick-tab.active {
    color: var(--color-primary);
    background: var(--color-bg-subtle);
  }

  .quick-pane {
    display: flex;
    flex-direction: column;
  }

  .recent-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    color: var(--color-text);
  }

  .recent-row + .recent-row {
    border-top: 1px solid var(--color-border);
  }

  .recent-row:hover {
    background: var(--color-bg-subtle);
  }

  .recent-thumb {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .recent-thumb-placeholder {
    background: var(--color-bg-subtle);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .recent-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .recent-title {
    font-size: 13px;
    color: var(--color-heading);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .recent-meta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-muted);
    font-size: 11px;
  }

  .quick-empty {
    padding: var(--space-lg);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 12px;
  }

  .stat-rows {
    display: flex;
    flex-direction: column;
  }

  .stat-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 0;
    font-size: 13px;
    color: var(--color-text);
  }

  .stat-row + .stat-row {
    border-top: 1px solid var(--color-border);
  }

  .stat-row > :global(svg) {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .stat-label {
    flex: 1;
    color: var(--color-text);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag-cloud .badge em {
    font-style: normal;
    color: var(--color-primary);
    margin-left: 2px;
  }

  .tag-link {
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .tag-link:hover {
    background: var(--color-primary);
    color: #fff;
  }

  .tag-link:hover em {
    color: rgba(255, 255, 255, 0.85);
  }
</style>
