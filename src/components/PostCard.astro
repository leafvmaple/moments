---
import Icon from './Icon.astro';

interface Props {
  title: string;
  date: Date;
  excerpt?: string;
  tags?: string[];
  href: string;
  cover?: string;
  author?: string;
  commentCount?: number;
  tripSlug?: string;
  tripName?: string;
}

const {
  title,
  date,
  excerpt,
  tags = [],
  href,
  cover,
  author = '叶枫影',
  commentCount = 0,
  tripSlug,
  tripName,
} = Astro.props;

const formattedDate = `${date.getFullYear()} 年 ${String(date.getMonth() + 1).padStart(2, '0')} 月 ${String(date.getDate()).padStart(2, '0')} 日`;
---

<article class="post-card" data-has-cover={cover ? 'true' : 'false'}>
  {cover && <img class="cover" src={cover} alt={title} loading="lazy" />}
  <div class="overlay">
    <a href={href} class="title-link">
      <h2 class="title">{title}</h2>
    </a>
    {excerpt && <p class="excerpt">{excerpt}</p>}
    <div class="meta">
      <span class="meta-item">
        <Icon name="user" size={13} />
        <span>{author}</span>
      </span>
      <span class="meta-item">
        <Icon name="clock" size={13} />
        <span>{formattedDate}</span>
      </span>
      <span class="meta-item">
        <Icon name="messageCircle" size={13} />
        <span>{commentCount} 条评论</span>
      </span>
      {
        tripSlug && tripName && (
          <a class="trip-chip" href={`/trips/${tripSlug}`}>
            <Icon name="activity" size={11} />
            <span>{tripName}</span>
          </a>
        )
      }
      {
        tags.length > 0 && (
          <span class="meta-tags">
            {tags.map((t) => (
              <a class="tag-chip" href={`/tags/${t}`}>
                #{t}
              </a>
            ))}
          </span>
        )
      }
    </div>
  </div>
</article>

<style>
  .post-card {
    position: relative;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    background: var(--color-bg-card);
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .post-card[data-has-cover='false'] {
    min-height: auto;
    padding: var(--space-xl);
  }

  .post-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .post-card[data-has-cover='true'] .overlay {
    position: relative;
    z-index: 1;
    padding: var(--space-xl) var(--space-xl) var(--space-lg);
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.85) 100%
    );
    color: #ececec;
  }

  .post-card[data-has-cover='true'] .title {
    color: #fff;
  }

  .post-card[data-has-cover='true'] .title-link:hover .title {
    color: var(--color-primary);
  }

  .post-card[data-has-cover='true'] .excerpt {
    color: rgba(255, 255, 255, 0.85);
  }

  .post-card[data-has-cover='true'] .meta {
    color: rgba(255, 255, 255, 0.75);
  }

  .title-link {
    color: var(--color-heading);
  }

  .title {
    font-size: 22px;
    margin: 0 0 var(--space-sm);
    transition: color 0.15s ease;
  }

  .excerpt {
    font-size: 14px;
    margin: 0 0 var(--space-md);
    line-height: 1.65;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .trip-chip {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: inherit;
    font-size: 11px;
    transition: background 0.15s ease;
  }

  .post-card[data-has-cover='false'] .trip-chip {
    background: var(--color-bg-subtle);
  }

  .trip-chip:hover {
    background: var(--color-primary);
    color: #fff;
  }

  .meta-tags {
    display: inline-flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .tag-chip {
    color: inherit;
    opacity: 0.85;
  }

  .tag-chip:hover {
    color: var(--color-primary);
    opacity: 1;
  }
</style>
