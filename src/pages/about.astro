---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const timeline = [
  { date: '2026-05', text: 'moments 站点上线。Astro 静态部署，复刻 Typecho handsome 调性。' },
  { date: '——', text: '在代码与生活的缝隙里写字。' },
];
---

<BaseLayout title="关于" description="关于 moments 与我。" pageTitle="关于">
  <section class="about-card panel">
    <header class="about-header">
      <div class="avatar">
        <img src="/images/avatar.jpg" alt="叶枫影" />
      </div>
      <div>
        <h1>叶枫影</h1>
        <p class="tagline">闲记</p>
        <div class="links">
          <a href="https://leafvmaple.com" target="_blank" rel="noopener noreferrer">
            <Icon name="link" size={13} /> <span>leafvmaple.com</span>
          </a>
          <a href="https://github.com/leafvmaple" target="_blank" rel="noopener noreferrer">
            <Icon name="github" size={13} /> <span>github.com/leafvmaple</span>
          </a>
        </div>
      </div>
    </header>

    <section class="about-section">
      <h2>关于网站</h2>
      <p>一个记录自己生活和感悟的小阁楼。</p>
    </section>

    <section class="about-section">
      <h2>关于我</h2>
      <p>坐标广东，某 MMORPG 客户端程序经理，同时也是剑网 3 枫影插件集作者。</p>
      <p>半个二次元，爱好摄影。</p>
      <p>主要技术栈：算法与数据结构、C++、Lua。</p>
    </section>

    <section class="about-section">
      <h2>时间线</h2>
      <ol class="timeline">
        {
          timeline.map((item) => (
            <li>
              <span class="t-date">{item.date}</span>
              <span class="t-text">{item.text}</span>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="about-section">
      <h2>联系</h2>
      <p>
        想交换友链 / 聊聊 / 指出错别字：通过 GitHub Issue 或邮箱（写在
        <a href="https://leafvmaple.com">主站</a> 页脚）。
      </p>
    </section>
  </section>
</BaseLayout>

<style>
  .about-card {
    padding: var(--space-xl);
  }

  .about-header {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .about-header h1 {
    margin: 0 0 var(--space-xs);
    font-size: 24px;
    font-weight: 600;
  }

  .tagline {
    margin: 0 0 var(--space-sm);
    color: var(--color-text-muted);
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent-green));
    flex-shrink: 0;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: 13px;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-primary);
  }

  .about-section {
    margin-bottom: var(--space-lg);
  }

  .about-section h2 {
    font-size: 16px;
    margin: 0 0 var(--space-sm);
    color: var(--color-heading);
    font-weight: 600;
  }

  .about-section p {
    margin: 0 0 var(--space-sm);
    line-height: 1.75;
  }

  .about-section a {
    color: var(--color-primary);
  }

  .placeholder-note {
    color: var(--color-text-muted);
    font-size: 13px;
    font-style: italic;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline li {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-md);
    position: relative;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 14px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .t-date {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    min-width: 70px;
    flex-shrink: 0;
  }

  .t-text {
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .about-header {
      flex-direction: column;
      text-align: center;
    }
    .links {
      justify-content: center;
    }
  }
</style>
