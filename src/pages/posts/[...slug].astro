---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Icon from '../../components/Icon.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: Awaited<ReturnType<typeof getCollection<'posts'>>>[number] };

const { post } = Astro.props as Props;
const { Content } = await render(post);

const formattedDate = `${post.data.date.getFullYear()} 年 ${String(post.data.date.getMonth() + 1).padStart(2, '0')} 月 ${String(post.data.date.getDate()).padStart(2, '0')} 日`;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  pageTitle={post.data.title}
  ogImage={post.data.cover}
  ogType="article"
>
  <div class="content-grid">
    <div class="content-main">
      <article class="post">
        {post.data.cover && <img src={post.data.cover} alt={post.data.title} class="post-cover" />}
        <div class="post-body">
          <h1 class="post-title">{post.data.title}</h1>
          <div class="post-meta">
            <span class="meta-item">
              <Icon name="user" size={13} />
              <span>leafvmaple</span>
            </span>
            <span class="meta-item">
              <Icon name="clock" size={13} />
              <span>{formattedDate}</span>
            </span>
            {
              post.data.tags.length > 0 && (
                <span class="post-tags">
                  {post.data.tags.map((t) => (
                    <a class="badge" href={`/tags/${t}`}>#{t}</a>
                  ))}
                </span>
              )
            }
          </div>
          <div class="markdown-body">
            <Content />
          </div>
        </div>
      </article>
      <Comments />
    </div>
    <Sidebar excludeSlug={post.id} />
  </div>
</BaseLayout>

<style>
  .post {
    background: var(--color-bg-card);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 6;
    object-fit: cover;
  }

  .post-body {
    padding: var(--space-xl);
  }

  .post-title {
    font-size: 26px;
    margin-bottom: var(--space-md);
    font-weight: 300;
  }

  .post-meta {
    color: var(--color-text-muted);
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding-bottom: var(--space-md);
    margin-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .post-tags {
    display: inline-flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-left: auto;
  }
</style>
